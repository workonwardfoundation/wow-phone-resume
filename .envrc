# AWS Configuration for wow-phone-resume
# This file automatically loads when you cd into this directory (requires direnv)
# If you don't have direnv, run: source .envrc

export AWS_PROFILE=wow-ai
export AWS_REGION=us-east-1
export AWS_ACCOUNT_ID=339635422111

# Project-specific variables
export CLUSTER_NAME=wow-phone-resume-cluster
export SERVICE_NAME=wow-phone-resume

# Display loaded config
echo "Project: wow-phone-resume"
echo "AWS Profile: $AWS_PROFILE"
echo "AWS Region: $AWS_REGION"
echo "AWS Account: $AWS_ACCOUNT_ID"

